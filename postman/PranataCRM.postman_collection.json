                "{{base_url}}"
              ],
              "path": [
                "companies",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Analytical"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Autocomplete source for the company_id picker on the contact form. Matches name/domain (case-insensitive), tenant-scoped, active companies only. q defaults to empty (returns the first N companies); limit is capped 1-50 server-side."
          }
        },
        {
          "name": "Lookup Companies",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Lookup returns an array', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies/lookup?ids={{company_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "companies",
                "lookup"
              ],
              "query": [
                {
                  "key": "ids",
                  "value": "{{company_id}}"
                }
              ]
            },
            "description": "Batch-resolves company_id values already saved on a contact back to display labels. ids is a comma-separated list of UUIDs; unparseable ids are skipped rather than erroring."
          }
        },
        {
          "name": "Delete Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Company deleted', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('company_id', '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/companies/{{company_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "companies",
                "{{company_id}}"
              ]
            },
            "description": "Clears the company_id variable on success."
          }
        }
      ]
    },
    {
      "name": "Cleanup & Extras",
      "description": "Run these last (or standalone). Logout clears the session cookies, so anything placed after it in a full collection run would fail with 401 — that's why it lives here instead of inside Auth.",
      "item": [
        {
          "name": "Accept Invite (manual token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const inviteToken = pm.environment.get('invite_token');",
                  "if (!inviteToken) {",
                  "    console.log('invite_token is empty — set it from the invite email/logs before running this request. Skipping the status assertion.');",
                  "} else {",
                  "    pm.test('Invite accepted', function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{invite_token}}\",\n  \"full_name\": \"{{invite_full_name}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/accept-invite",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "accept-invite"
              ]
            },
            "description": "MANUAL STEP REQUIRED: set the invite_token environment variable to the JWT sent by the \"Invite User\" request's email (or read it from the backend logs) before running this. Without it, this intentionally returns 400 and the test is skipped rather than failed."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout succeeded', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.environment.set('access_token', '');",
                  "pm.environment.set('refresh_token', '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "description": "Revokes the refresh token and clears the captured access_token/refresh_token variables. Placed last on purpose — run this only when you're done testing."
          }
        }
      ]
    }
  ]
}
