      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique tenant slug + email every time this request runs,",
                  "// so re-running it (or the whole collection) never collides with a",
                  "// previous run's data (AUTH_SLUG_TAKEN / AUTH_EMAIL_EXISTS).",
                  "const runSuffix = Date.now();",
                  "pm.environment.set('tenant_slug', 'postman-' + runSuffix);",
                  "pm.environment.set('test_email', 'postman+' + runSuffix + '@example.com');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Tenant registered', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('tenant_id', body.tenant_id);",
                  "    pm.environment.set('user_id', body.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"{{test_full_name}}\",\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\",\n  \"organization_name\": \"{{organization_name}}\",\n  \"slug\": \"{{tenant_slug}}\",\n  \"industry\": \"{{industry}}\",\n  \"team_size\": \"{{team_size}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register-tenant",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register-tenant"
              ]
            },
            "description": "Creates a brand-new tenant + owner user. Does NOT log in automatically. Run Login next."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.environment.set('user_id', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\",\n  \"password\": \"{{test_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Uses the dev-mode X-Tenant-Slug header (auto-injected from the tenant_slug variable) instead of a real subdomain. On success, access_token/refresh_token cookies are captured automatically by the collection-level test script."
          }
        },
        {
          "name": "Get Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns current user profile', function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.have.property('email');",
                  "});"
                ]
